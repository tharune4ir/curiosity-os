{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://curiosity-os.local/schema/master_universe_v1.json",
  "title": "Curiosity OS Master Universe Schema v1",
  "description": "Schema for the canonical topic-first atomic graph used by the Curiosity OS 3D universe, PKMS, and curriculum reference layer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "curriculum",
    "nodes",
    "edges",
    "indexes",
    "meta"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "curiosity-os.atom-graph.v1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "curriculum": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "wing_system"
      ],
      "properties": {
        "name": {
          "type": "string",
          "const": "Curiosity OS"
        },
        "wing_system": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "$ref": "#/$defs/wing"
          }
        }
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    },
    "indexes": {
      "$ref": "#/$defs/indexes"
    },
    "meta": {
      "$ref": "#/$defs/meta"
    }
  },
  "$defs": {
    "wing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wing_number",
        "wing_code",
        "short_name",
        "long_name"
      ],
      "properties": {
        "wing_number": {
          "type": "integer",
          "enum": [
            1,
            2,
            3,
            4
          ]
        },
        "wing_code": {
          "type": "string",
          "enum": [
            "W1",
            "W2",
            "W3",
            "W4"
          ]
        },
        "short_name": {
          "type": "string",
          "enum": [
            "Decode",
            "Cognition",
            "Relate",
            "Sandbox"
          ]
        },
        "long_name": {
          "type": "string"
        }
      }
    },
    "taxonomy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wing_number",
        "wing_code",
        "wing_short_name",
        "wing_long_name",
        "arena_title",
        "module_number",
        "module_title",
        "curriculum_path"
      ],
      "properties": {
        "wing_number": {
          "type": "integer",
          "enum": [
            1,
            2,
            3,
            4
          ]
        },
        "wing_code": {
          "type": "string",
          "enum": [
            "W1",
            "W2",
            "W3",
            "W4"
          ]
        },
        "wing_short_name": {
          "type": "string",
          "enum": [
            "Decode",
            "Cognition",
            "Relate",
            "Sandbox"
          ]
        },
        "wing_long_name": {
          "type": "string"
        },
        "arena_title": {
          "type": [
            "string",
            "null"
          ]
        },
        "module_number": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "module_title": {
          "type": [
            "string",
            "null"
          ]
        },
        "curriculum_path": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string"
          }
        },
        "zone_title": {
          "type": [
            "string",
            "null"
          ]
        },
        "embedded_under_title": {
          "type": [
            "string",
            "null"
          ]
        },
        "curriculum_code": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "classification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domain",
        "tags",
        "keywords"
      ],
      "properties": {
        "domain": {
          "type": [
            "string",
            "null"
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hook",
        "meaning",
        "why_it_matters",
        "example",
        "teaching_prompt",
        "summary_short",
        "summary_long"
      ],
      "properties": {
        "hook": {
          "type": "string"
        },
        "meaning": {
          "type": "string"
        },
        "why_it_matters": {
          "type": "string"
        },
        "example": {
          "type": "string"
        },
        "teaching_prompt": {
          "type": "string"
        },
        "summary_short": {
          "type": "string",
          "maxLength": 240
        },
        "summary_long": {
          "type": "string"
        }
      }
    },
    "pedagogy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "difficulty",
        "age_band",
        "estimated_minutes",
        "teaching_modes",
        "misconceptions",
        "prerequisite_ids",
        "recommended_after_ids"
      ],
      "properties": {
        "difficulty": {
          "type": "string",
          "enum": [
            "beginner",
            "intermediate",
            "advanced"
          ]
        },
        "age_band": {
          "type": "string"
        },
        "estimated_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "teaching_modes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "concept",
              "mental-model",
              "decision-tool",
              "social-skill",
              "practice",
              "reflection",
              "simulation",
              "game",
              "project"
            ]
          },
          "uniqueItems": true
        },
        "misconceptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "prerequisite_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^COS-[0-9]{4,}$"
          },
          "uniqueItems": true
        },
        "recommended_after_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^COS-[0-9]{4,}$"
          },
          "uniqueItems": true
        }
      }
    },
    "activity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "activity_id",
        "title",
        "type",
        "mode",
        "duration_minutes",
        "objective",
        "prompt",
        "materials",
        "tags"
      ],
      "properties": {
        "activity_id": {
          "type": "string",
          "pattern": "^ACT-COS-[0-9]{4,}-[0-9]{2}$"
        },
        "title": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "micro-exercise",
            "mini-game",
            "discussion",
            "journal",
            "roleplay",
            "challenge",
            "experiment",
            "project"
          ]
        },
        "mode": {
          "type": "string",
          "enum": [
            "solo",
            "pair",
            "group",
            "solo_or_group"
          ]
        },
        "duration_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "objective": {
          "type": "string"
        },
        "prompt": {
          "type": "string"
        },
        "materials": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "graph": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "linked_node_ids",
        "wikilinks"
      ],
      "properties": {
        "linked_node_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^COS-[0-9]{4,}$"
          },
          "uniqueItems": true
        },
        "wikilinks": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^\\[\\[[^\\]]+\\]\\]$"
          },
          "uniqueItems": true
        }
      }
    },
    "display": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "color_group": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        },
        "default_open_section": {
          "type": "string"
        }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "sequence_number",
        "slug",
        "title",
        "display_title",
        "node_type",
        "visibility",
        "taxonomy",
        "classification",
        "content",
        "graph"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^COS-[0-9]{4,}$"
        },
        "sequence_number": {
          "type": "integer",
          "minimum": 1
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "display_title": {
          "type": "string",
          "minLength": 1
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "node_type": {
          "type": "string",
          "enum": [
            "topic",
            "embedded_topic",
            "practice_zone",
            "practice_atom",
            "outcome"
          ]
        },
        "visibility": {
          "type": "string",
          "enum": [
            "public",
            "internal",
            "hidden"
          ]
        },
        "taxonomy": {
          "$ref": "#/$defs/taxonomy"
        },
        "classification": {
          "$ref": "#/$defs/classification"
        },
        "content": {
          "$ref": "#/$defs/content"
        },
        "pedagogy": {
          "$ref": "#/$defs/pedagogy"
        },
        "activities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/activity"
          }
        },
        "graph": {
          "$ref": "#/$defs/graph"
        },
        "display": {
          "$ref": "#/$defs/display"
        },
        "frontmatter": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "from",
        "to",
        "type",
        "strength",
        "bidirectional",
        "reason"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^EDGE-[0-9]{6,}$"
        },
        "from": {
          "type": "string",
          "pattern": "^COS-[0-9]{4,}$"
        },
        "to": {
          "type": "string",
          "pattern": "^COS-[0-9]{4,}$"
        },
        "type": {
          "type": "string",
          "enum": [
            "builds_on",
            "related_to",
            "reinforces",
            "contrasts_with",
            "embedded_in",
            "practiced_in",
            "leads_to",
            "supports"
          ]
        },
        "strength": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "bidirectional": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "indexes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "by_id",
        "by_slug",
        "by_title",
        "by_tag",
        "by_wing",
        "by_module",
        "by_node_type",
        "by_visibility"
      ],
      "properties": {
        "by_id": {
          "type": "object",
          "additionalProperties": {
            "type": "integer"
          }
        },
        "by_slug": {
          "type": "object",
          "additionalProperties": {
            "type": "integer"
          }
        },
        "by_title": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          }
        },
        "by_tag": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          }
        },
        "by_wing": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          }
        },
        "by_module": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          }
        },
        "by_node_type": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          }
        },
        "by_visibility": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          }
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_count",
        "edge_count",
        "node_type_counts",
        "wing_counts"
      ],
      "properties": {
        "node_count": {
          "type": "integer",
          "minimum": 0
        },
        "edge_count": {
          "type": "integer",
          "minimum": 0
        },
        "node_type_counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "wing_counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}